local function findMobByItem(itemName)
    for mobName, data in pairs(ItemDatabase) do
        if table.find(data.Items, itemName) then return mobName, data.Npc end
    end
    return nil, nil
end

local function getItemAmount(itemName)
    local amount = 0
    pcall(function()
        local inventory = LocalPlayer.PlayerGui.HUD.Main.Frame_Inventory.Handler.InventoryHandler.ScrollingFrame
        local itemObj = inventory:FindFirstChild(itemName)
        if itemObj and itemObj.Main:FindFirstChild("Amount") then
            amount = parseNumberString(itemObj.Main.Amount.Text)
        end
    end)
    return amount
end

local function checkOwnedItem(itemName)
    if not itemName or itemName == "None" then return false end
    if LocalPlayer.Backpack:FindFirstChild(itemName) or LocalPlayer.Character:FindFirstChild(itemName) then return true end
    local isOwned = false
    pcall(function()
        if LocalPlayer.PlayerGui.HUD.Main.Frame_Inventory.Handler.InventoryHandler.ScrollingFrame:FindFirstChild(itemName) then
            isOwned = true
        end
    end)
    return isOwned
end

local function getAvailableWeapons()
    local weapons = {"None"}
    local function checkFolder(folder)
        for _, v in ipairs(folder:GetChildren()) do
            if v:IsA("Tool") and not table.find(weapons, v.Name) then table.insert(weapons, v.Name) end
        end
    end
    checkFolder(LocalPlayer.Backpack)
    if LocalPlayer.Character then checkFolder(LocalPlayer.Character) end
    return weapons
end

local function equipAndGetWeapon()
    local weaponName = SelectedWeapon
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChildOfClass("Humanoid") then return nil end
    if not weaponName or weaponName == "None" or weaponName == "" then
        local currentTool = character:FindFirstChildOfClass("Tool")
        return currentTool and currentTool.Name
    end
    if character:FindFirstChild(weaponName) then return weaponName end
    local backpackTool = LocalPlayer.Backpack:FindFirstChild(weaponName)
    if backpackTool and character.Humanoid.Health > 0 then
        if os.clock() - lastEquipTime > 0.3 then
            lastEquipTime = os.clock()
            character.Humanoid:EquipTool(backpackTool)
        end
        return weaponName
    end
    return nil
end

local function realHoldButton(btn)
    if btn and btn.Visible then
        pcall(function()
            if firesignal then
                firesignal(btn.MouseButton1Click)
                firesignal(btn.Activated)
            else
                local inset, _ = GuiService:GetGuiInset()
                local x = btn.AbsolutePosition.X + (btn.AbsoluteSize.X / 2) + inset.X
                local y = btn.AbsolutePosition.Y + (btn.AbsoluteSize.Y / 2) + inset.Y
                VirtualInputManager:SendTouchEvent(1, 0, x, y)
                task.wait(0.05)
                VirtualInputManager:SendTouchEvent(1, 2, x, y)
            end
        end)
    end
end

local function autoDetectType(itemName)
    local swordFolder = ReplicatedStorage:WaitForChild("Weapon"):FindFirstChild("Sword")
    if swordFolder and swordFolder:FindFirstChild(itemName) then return "Sword" end
    return "Melee"
end

local function getAllMissingMaterials(itemName, list)
    list = list or {}
    if checkOwnedItem(itemName) then return list end
    local recipeData = CraftDatabase[itemName]
    if not recipeData then return list end
    
    local mats = recipeData.Materials
    if not mats then return list end

    for mat, needed in pairs(mats) do
        if mat ~= "Beli" then
            if CraftDatabase[mat] then
                if not checkOwnedItem(mat) then
                    getAllMissingMaterials(mat, list)
                end
            else
                local currentAmt = getItemAmount(mat)
                if currentAmt < needed then
                    table.insert(list, {Name = mat, Needed = needed, Current = currentAmt})
                end
            end
        end
    end
    return list
end

local function getCurrentCraftTarget(itemName)
    if checkOwnedItem(itemName) then return nil end
    local recipeData = CraftDatabase[itemName]
    if not recipeData then return nil end
    
    local missing = getAllMissingMaterials(itemName)
    
    if #missing > 0 then
        local FolderMon = workspace:FindFirstChild("Mob") or workspace
        for _, matData in ipairs(missing) do
            local mobName, npcName = findMobByItem(matData.Name)
            if mobName then
                for _, m in ipairs(FolderMon:GetChildren()) do
                    if m.Name == mobName and m:FindFirstChildOfClass("Humanoid") and m.Humanoid.Health > 0 and m:FindFirstChild("HumanoidRootPart") then
                        if m.HumanoidRootPart.Position.Y > -500 then
                            return "farm", matData.Name, matData.Needed
                        end
                    end
                end
            end
        end
        
        local firstMissing = missing[1]
        return "farm", firstMissing.Name, firstMissing.Needed
    end
    
    local mats = recipeData.Materials
    local beliNeeded = mats and mats["Beli"] or 0
    if getBeliAmount() < beliNeeded then 
        return "beli", "Beli", beliNeeded 
    end
    
    return "craft", itemName, 1
end

local function updateDashboardUI()
    for _, child in ipairs(DashScroll:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
    
    if SelectedCraftItem == "None" or checkOwnedItem(SelectedCraftItem) then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 0, 25)
        lbl.BackgroundTransparency = 1
        lbl.Font = Enum.Font.SourceSans
        lbl.Text = SelectedCraftItem == "None" and "Please Select Item to Craft" or "Item Already Crafted!"
        lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        lbl.TextSize = 14
        lbl.Parent = DashScroll
        DashScroll.CanvasSize = UDim2.new(0, 0, 0, 25)
        return
    end

    local recipeData = CraftDatabase[SelectedCraftItem]
    if not recipeData then return end
    local mats = recipeData.Materials
    if not mats then return end

    local totalHeight = 0
    for matName, neededAmt in pairs(mats) do
        local currentAmt = 0
        local isBeli = (matName == "Beli")
        
        if isBeli then
            currentAmt = getBeliAmount()
        else
            currentAmt = getItemAmount(matName)
        end
        
        local missingAmt = neededAmt - currentAmt
        if missingAmt < 0 then missingAmt = 0 end
        
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 0, 25)
        lbl.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
        lbl.BorderSizePixel = 0
        lbl.Font = Enum.Font.SourceSans
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        
        if missingAmt == 0 then
            lbl.Text = "  " .. matName .. ": DONE (" .. currentAmt .. "/" .. neededAmt .. ")"
            lbl.TextColor3 = Color3.fromRGB(50, 220, 50)
        else
            lbl.Text = "  " .. matName .. ": Need " .. missingAmt .. " (" .. currentAmt .. "/" .. neededAmt .. ")"
            lbl.TextColor3 = Color3.fromRGB(220, 50, 50)
        end
        
        lbl.TextSize = 13
        lbl.Parent = DashScroll
        totalHeight = totalHeight + 29
    end
    
    DashScroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

local function executeCraftingCheck()
    if not getgenv().AutoCraft or SelectedCraftItem == "None" then
        FarmingBeliForCraft = false
        CraftFarmItem = "None"
        return
    end

    if checkOwnedItem(SelectedCraftItem) then
        FarmingBeliForCraft = false
        CraftFarmItem = "None"
        getgenv().AutoCraft = false
        return
    end

    local actionType, targetName, amountNeeded = getCurrentCraftTarget(SelectedCraftItem)

    if actionType == "beli" then
        FarmingBeliForCraft = true
        CraftFarmItem = "None"
    elseif actionType == "farm" then
        FarmingBeliForCraft = false
        CraftFarmItem = targetName
        CraftFarmLimit = amountNeeded
    elseif actionType == "craft" then
        FarmingBeliForCraft = false
        CraftFarmItem = "None"
        TargetMob = nil
        NetworkEvent:FireServer("fire", nil, "Craft", targetName, autoDetectType(targetName))
        task.wait(0.5)
    elseif actionType == "unfarmable" then
        FarmingBeliForCraft = false
        CraftFarmItem = "None"
        getgenv().AutoCraft = false 
    end
end

local function determineFarmTarget()
    local Mon, Npc, tierIndex = nil, nil, nil

    if getgenv().AutoFarmBoss and SelectedBoss ~= "None" then
        Mon = SelectedBoss
        tierIndex = "Boss_" .. SelectedBoss
    end

    if not Mon and getgenv().AutoCraft and SelectedCraftItem ~= "None" then
        if FarmingBeliForCraft then
            Mon, Npc, _ = getMon()
            tierIndex = "Beli_Farm_Level"
        elseif CraftFarmItem ~= "None" then
            local monName, npcName = findMobByItem(CraftFarmItem)
            if monName then Mon = monName Npc = npcName tierIndex = "CraftItem_" .. CraftFarmItem end
        end
    end

    if not Mon and getgenv().AutoFarmItem and SelectedFarmItem ~= "None" then
        if getItemAmount(SelectedFarmItem) < ItemFarmLimit then
            local monName, npcName = findMobByItem(SelectedFarmItem)
            if monName then Mon = monName Npc = npcName tierIndex = "ManualItem_" .. SelectedFarmItem end
        end
    end

    if not Mon and getgenv().Autofarm then
        Mon, Npc, _ = getMon()
        tierIndex = "Level_Farm"
    end

    return Mon, Npc, tierIndex
end

local function executeFarmingCycle()
    local Mon, Npc, tierIndex = determineFarmTarget()
    if not Mon or Mon == "" then TargetMob = nil return end

    pcall(function()
        local character = LocalPlayer.Character
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then TargetMob = nil return end
        
        local FolderMon = workspace:FindFirstChild("Mob") or workspace
        if tierIndex and tierIndex:find("Boss_") then
            FolderMon = workspace:FindFirstChild("Boss") or FolderMon
        end
        
        local questFrame = LocalPlayer.PlayerGui.HUD.Main:FindFirstChild("Frame_Quest")
        if questFrame and questFrame.Visible and questFrame:FindFirstChild("Title") then
            local questTitle = questFrame.Title.Text
            if not string.find(questTitle, Mon) then
                getgenv().IsTransitioning = true
                TargetMob = nil
                NetworkEvent:FireServer("fire", nil, "Quest", "Cancel")
                questFrame.Visible = false
                task.wait(0.3)
                getgenv().IsTransitioning = false
            end
        end

        if currentTier ~= tierIndex then
            getgenv().IsTransitioning = true
            TargetMob = nil
            NetworkEvent:FireServer("fire", nil, "Quest", "Cancel")
            if LocalPlayer.PlayerGui.HUD.Main:FindFirstChild("Frame_Quest") then LocalPlayer.PlayerGui.HUD.Main.Frame_Quest.Visible = false end
            task.wait(0.3)
            currentTier = tierIndex
            getgenv().IsTransitioning = false
        end

        local hasQuest = LocalPlayer.PlayerGui.HUD.Main.Frame_Quest.Visible
        local npc = Npc and workspace:FindFirstChild("NpcQuest") and workspace.NpcQuest:FindFirstChild(Npc)
        
        local shouldAcceptQuest = false
        if tierIndex == "Level_Farm" or tierIndex == "Beli_Farm_Level" then
            shouldAcceptQuest = true
        end
        
        if shouldAcceptQuest and not hasQuest and npc and npc:FindFirstChild("HumanoidRootPart") then
            getgenv().IsTransitioning = true
            TargetMob = nil
            character.Humanoid.PlatformStand = true
            character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
            character.HumanoidRootPart.AssemblyAngularVelocity = Vector3.zero
            character.HumanoidRootPart.CFrame = npc.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) 
            task.wait(0.3) 
            
            if fireproximityprompt then
                for _, v in ipairs(npc:GetDescendants()) do if v:IsA("ProximityPrompt") then fireproximityprompt(v) task.wait(0.05) end end
            end
            task.wait(0.3)
            
            for _, v in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
                if v:IsA("TextButton") and v.Visible then
                    local name, text = v.Name:lower(), v.Text:lower()
                    if name:find("accept") or name:find("quest") or text:find("accept") or text:find("รับ") then
                        realHoldButton(v)
                        task.wait(0.2)
                        break
                    end
                end
            end
            getgenv().IsTransitioning = false
            return
        end

        local foundMob = nil
        for _, mob in ipairs(FolderMon:GetChildren()) do
            if mob.Name == Mon and mob:FindFirstChildOfClass("Humanoid") and mob.Humanoid.Health > 0 and mob:FindFirstChild("HumanoidRootPart") then
                if mob.HumanoidRootPart.Position.Y > -500 then
                    foundMob = mob
                    break
                end
            end
        end

        if not foundMob then
            TargetMob = nil
            return
        end

        TargetMob = foundMob
    end)
end

local function startAttackLoop()
