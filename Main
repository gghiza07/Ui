function ui:CreateWindow(options)
    options = options or {}
    
    local function sanitize(str)
        return string.gsub(str, "[^%w%s%-_]", "")
    end
    
    local mapName = options.Map or "Unknow map"
    local saveFile = (options.Save and options.Save.SaveFile ~= "" and options.Save.SaveFile) or (sanitize(mapName) .. ".json")
    
    local config = {
        Name = options.Name or "Wiv",
        MapName = mapName,
        LogoText = options.Text or "",
        Width = 0.36,
        Height = 0.62,
        SaveConfig = true,
        SaveFolder = "settingsUi",
        SaveFile = saveFile,
        ToggleKey = Enum.KeyCode.LeftControl,
        Theme = {
            Primary = Color3.fromRGB(14, 16, 20),
            Accent = Color3.fromRGB(84, 240, 255),
            Accent2 = Color3.fromRGB(150, 80, 255),
            Text = Color3.fromRGB(230, 230, 230),
            Sub = Color3.fromRGB(26, 28, 32)
        }
    }
    
    if options.Save then
        config.SaveConfig = options.Save.SaveConfig ~= nil and options.Save.SaveConfig or config.SaveConfig
