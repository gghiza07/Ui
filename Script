local function Level()
    local hud = LocalPlayer:FindFirstChild("PlayerGui") and LocalPlayer.PlayerGui:FindFirstChild("HUD")
    if hud and hud.Main.Frame_Display.LevelText then
        return tonumber(string.match(hud.Main.Frame_Display.LevelText.Text, "%d+")) or 1
    end
    return 1
end

local function getMaxLevel()
    if #levelconfig > 0 then
        return levelconfig[#levelconfig].lvm
    end
    return 0
end

local function getMon()
    local lv = Level()
    for i, config in pairs(levelconfig) do
        if lv >= config.lvl and lv <= config.lvm then return config.Mon, config.Npc, i end
    end
    return nil, nil, nil
end

local function parseNumberString(text)
    if not text then return 0 end
    local cleanText = string.gsub(text, ",", "")
    local numStr = string.match(cleanText, "[%d%.]+")
    local num = tonumber(numStr) or 0
    
    local upperText = string.upper(cleanText)
    if string.find(upperText, "T") then
        num = num * 1000000000000
    elseif string.find(upperText, "B") then
        num = num * 1000000000
    elseif string.find(upperText, "M") then
        num = num * 1000000
    elseif string.find(upperText, "K") then
        num = num * 1000
    end
    
    return math.floor(num + 0.5)
end

local function getBeliAmount()
