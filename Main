    titleAndMapLayout.FillDirection = Enum.FillDirection.Horizontal
    titleAndMapLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    titleAndMapLayout.Padding = UDim.new(0, -1)
    titleAndMapLayout.Parent = titleAndMapFrame

    local title = Instance.new("TextLabel")
    title.Name = "Title"
    title.Size = UDim2.new(0, 0, 0, 16)
